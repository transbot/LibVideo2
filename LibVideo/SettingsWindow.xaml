<Window x:Class="LibVideo.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource SettingsWindowTitle}" Height="450" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <TextBlock Text="{DynamicResource ScanDirectoryLabel}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
        
        <ListBox x:Name="dirListUI" Grid.Row="1" Style="{StaticResource MaterialDesignListBox}" 
                 ItemsSource="{Binding Directories}" SelectedItem="{Binding SelectedDirectory}" 
                 Margin="0,0,0,16" Background="#f5f5f5" />
                 
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource AddVideoDirectory}" Style="{StaticResource MaterialDesignRaisedButton}" Click="AddDir_Click" Margin="0,0,10,0" />
            <Button Content="{DynamicResource DeleteSelected}" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding DeleteSelectedDirectoryCommand}" Foreground="#c62828" BorderBrush="#c62828" />
        </StackPanel>
        
        <Separator Grid.Row="3" Margin="0,16,0,16" />
        
        <TextBlock Grid.Row="4" Text="{DynamicResource CustomPlayerLabel}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding CustomPlayerPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="{DynamicResource CustomPlayerHint}" Height="45" Margin="0,0,10,0" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="{DynamicResource BrowseButton}" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding SelectPlayerCommand}" VerticalAlignment="Center" />
        </Grid>
        

        
        <Button Grid.Row="8" Content="{DynamicResource OKButton}" Style="{StaticResource MaterialDesignRaisedButton}" Click="OkButton_Click" Width="100" HorizontalAlignment="Right" Margin="0,10,0,0" />
    </Grid>
</Window>
