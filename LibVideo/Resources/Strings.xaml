<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <!-- Settings Strings -->
    <system:String x:Key="SettingsWindowTitle">设置</system:String>
    <system:String x:Key="ScanDirectoryLabel">配置您的视频扫描目录：</system:String>
    <system:String x:Key="AddVideoDirectory">添加视频目录</system:String>
    <system:String x:Key="DeleteSelected">删除选中</system:String>
    <system:String x:Key="CustomPlayerLabel">自定义播放器：</system:String>
    <system:String x:Key="CustomPlayerHint">在此填写或浏览播放器完整路径（若留空则自动检测 PotPlayer）</system:String>
    <system:String x:Key="BrowseButton">浏览</system:String>
    <system:String x:Key="UILanguageLabel">界面语言：</system:String>
    <system:String x:Key="OKButton">确定</system:String>
    <system:String x:Key="AboutWindowTitle">关于 LibVideo</system:String>
    <system:String x:Key="AboutDescription">LibVideo 是一款本地影视及音乐库管理工具，为您提供无缝的沉浸式选片体验。</system:String>
    <system:String x:Key="AboutToolTip">关于 / 作者主页</system:String>

    <!-- MainWindow Strings -->
    <system:String x:Key="MainWindowTitle">我家视频</system:String>
    <system:String x:Key="SearchHint">搜索视频文件...</system:String>
    <system:String x:Key="PrevSearchToolTip">上一个搜索</system:String>
    <system:String x:Key="NextSearchToolTip">下一个搜索</system:String>
    <system:String x:Key="RefreshCacheToolTip">清空海报与简介缓存库 (重置识别)</system:String>
    <system:String x:Key="SettingsToolTip">设置与管理视频目录</system:String>
    <system:String x:Key="PlayVideoToolTip">播放该视频</system:String>
    <system:String x:Key="OpenFolderToolTip">打开所在文件夹</system:String>
    <system:String x:Key="HeaderId">编号</system:String>
    <system:String x:Key="HeaderPath">路径</system:String>
    <system:String x:Key="HeaderFileName">文件名</system:String>
    <system:String x:Key="MenuPlay">播放</system:String>
    <system:String x:Key="MenuOpenFolder">打开文件夹</system:String>
    <system:String x:Key="LoadingText">正在加载文件，请稍候...</system:String>

    <!-- Dialog Strings -->
    <system:String x:Key="DialogRefreshCacheMsg">此操作将清空当前读取的所有海报、影片简介等缓存元数据，并在后台重新扫描和匹配（可能会需要较长的时间来请求TMDB接口）。您确定要清空并刷新缓存吗？</system:String>
    <system:String x:Key="SettingsHintText">请先点击此处配置您的影音目录！</system:String>
    <system:String x:Key="DialogRefreshCacheTitle">清空元数据缓存</system:String>
    <system:String x:Key="DialogNoIsoFound">在该目录下未发现 ISO 文件。</system:String>
    <system:String x:Key="DialogErrorTitle">错误</system:String>
    <system:String x:Key="DialogPathInvalid">路径无效或尚未准备好。</system:String>
    <system:String x:Key="DialogSelectFolderTitle">选择文件夹</system:String>
    <system:String x:Key="DialogSelectPlayerTitle">选择自定义播放器</system:String>

    <!-- StatusBar Strings -->
    <system:String x:Key="StatusTotalItems">媒体文件或文件夹共计: {0} 个</system:String>
</ResourceDictionary>
