<Window x:Class="LibVideo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibVideo"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        Title="{DynamicResource MainWindowTitle}" Height="600" Width="1000"
        WindowState="Normal" WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <localViewModels:MainViewModel xmlns:localViewModels="clr-namespace:LibVideo.ViewModels"/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Grid Grid.Row="0" Margin="16,10,16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <ComboBox x:Name="keywords" Style="{StaticResource MaterialDesignFloatingHintComboBox}" materialDesign:HintAssist.Hint="{DynamicResource SearchHint}" materialDesign:TextFieldAssist.HasClearButton="True" ItemsSource="{Binding SearchHistory}" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" Height="45" Width="300" VerticalAlignment="Center" Margin="0,0,10,0">
                    <ComboBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding CommitSearchCommand}"/>
                    </ComboBox.InputBindings>
                </ComboBox>
                <Button x:Name="btnPrevSearch" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Command="{Binding PrevSearchCommand}" Height="30" Width="30" ToolTip="{DynamicResource PrevSearchToolTip}" VerticalAlignment="Center" Margin="0,0,10,0">
                    <materialDesign:PackIcon Kind="ChevronLeft" />
                </Button>
                <Button x:Name="btnNextSearch" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Command="{Binding NextSearchCommand}" Height="30" Width="30" ToolTip="{DynamicResource NextSearchToolTip}" VerticalAlignment="Center" Margin="0,0,10,0">
                    <materialDesign:PackIcon Kind="ChevronRight" />
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                <Button x:Name="btnAbout" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Click="btnAbout_Click" Height="40" Width="40" ToolTip="{DynamicResource AboutToolTip}" Margin="0,0,10,0" Background="{DynamicResource PrimaryHueMidBrush}" BorderBrush="Transparent">
                    <materialDesign:PackIcon Kind="InformationOutline" Height="24" Width="24" Foreground="White" />
                </Button>
                <Button Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Command="{Binding RefreshCacheCommand}" Height="40" Width="40" ToolTip="{DynamicResource RefreshCacheToolTip}" Margin="0,0,10,0" Background="{DynamicResource PrimaryHueDarkBrush}" BorderBrush="Transparent">
                    <materialDesign:PackIcon Kind="DatabaseRefresh" Height="24" Width="24" Foreground="White" />
                </Button>
                <Button x:Name="btnSettings" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Click="btnSettings_Click" Height="40" Width="40" ToolTip="{DynamicResource SettingsToolTip}">
                    <materialDesign:PackIcon Kind="Settings" Height="24" Width="24" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main DataGrid -->
        <DataGrid Grid.Row="1" x:Name="outputGrid" SelectedItem="{Binding SelectedVideo}" Style="{StaticResource MaterialDesignDataGrid}" ItemsSource="{Binding VideoItems}" Margin="16,0,16,16" AutoGenerateColumns="False" SelectionMode="Single" SelectionUnit="FullRow" IsReadOnly="true" VirtualizingPanel.IsVirtualizing="True">
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                    <EventSetter Event="MouseDoubleClick" Handler="Row_DoubleClick" />
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Style="{StaticResource MaterialDesignIconButton}" 
                                        Command="{Binding DataContext.OpenMediaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Width="30" Height="30" Padding="0" Margin="0,0,5,0"
                                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                                        ToolTip="{DynamicResource PlayVideoToolTip}">
                                    <materialDesign:PackIcon Kind="Play" Width="20" Height="20" />
                                </Button>
                                <Button Style="{StaticResource MaterialDesignIconButton}" 
                                        Command="{Binding DataContext.OpenContainingFolderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Width="30" Height="30" Padding="0" Margin="0"
                                        Foreground="{DynamicResource SecondaryHueMidBrush}"
                                        ToolTip="{DynamicResource OpenFolderToolTip}">
                                    <materialDesign:PackIcon Kind="FolderOpen" Width="20" Height="20" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Binding="{Binding Id}">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{DynamicResource HeaderId}" />
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding FolderName}" Width="*">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{DynamicResource HeaderPath}" />
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding FileName}" Width="*">
                    <DataGridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{DynamicResource HeaderFileName}" />
                        </DataTemplate>
                    </DataGridTextColumn.HeaderTemplate>
                </DataGridTextColumn>
            </DataGrid.Columns>

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{DynamicResource MenuPlay}" Click="PlayOrOpenItem" />
                    <MenuItem Header="{DynamicResource MenuOpenFolder}" Click="OpenContainingFolder" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <!-- Metadata Bottom Panel (Cinematic Glassmorphism) -->
        <Border Grid.Row="2" Margin="16,0,16,10" CornerRadius="8" ClipToBounds="True" Height="200" Visibility="{Binding IsMetadataVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <!-- 1. Thematic Background (Heavily Blurred Poster) -->
                <Image Source="{Binding CurrentMetadata.PosterPath}" Stretch="UniformToFill" Margin="-30" RenderOptions.BitmapScalingMode="LowQuality">
                    <Image.Effect>
                        <BlurEffect Radius="60" KernelType="Gaussian" />
                    </Image.Effect>
                </Image>
                
                <!-- 2. Dark Legibility Gradient Tint -->
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#E6000000" Offset="0" />
                            <GradientStop Color="#C0000000" Offset="0.8" />
                            <GradientStop Color="#99000000" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- 3. Crisp Foreground Content -->
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="115" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" CornerRadius="4" ClipToBounds="True">
                        <Image Source="{Binding CurrentMetadata.PosterPath}" Stretch="UniformToFill" />
                    </Border>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,10,0">
                        <TextBlock Text="{Binding CurrentMetadata.Title}" FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,0,0,6" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding CurrentMetadata.Genre}" FontSize="13" Foreground="#B3FFFFFF" Margin="0,0,0,10" />
                        <TextBlock Text="{Binding CurrentMetadata.Plot}" FontSize="14" Foreground="#E6FFFFFF" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="85" LineHeight="20" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock x:Name="totalItemsText" Text="{Binding TotalItemsText}"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="itemsAddedLast24HoursText" Text="{Binding ItemsAddedLast24HoursText}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="4" x:Name="LoadingOverlay" Background="#99000000" Panel.ZIndex="100" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True" Width="50" Height="50" Margin="0,0,0,16" Foreground="White" />
                <TextBlock Text="{DynamicResource LoadingText}" Foreground="White" FontSize="20"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
